{
  "name": "free-stack-starter",
  "version": "1.0.0",
  "private": true,
  "description": "A curated directory of free and open-source tools for development, DevOps, IT, design, data and productivity — built as a real $0 stack example.",
  "license": "MIT",
  "engines": { "node": ">=18.18" },
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "typecheck": "tsc --noEmit",
    "test": "node -e \"require('fs').rmSync('.tmp-tests',{recursive:true,force:true})\" && tsc -p tsconfig.tests.json && node --test .tmp-tests/tests/catalog-parser.test.js .tmp-tests/tests/service-search.test.js",
    "catalog:validate": "node -e \"require('fs').rmSync('.tmp-tools',{recursive:true,force:true})\" && tsc -p tsconfig.tools.json && node .tmp-tools/scripts/catalog-report.js --validate",
    "catalog:stats": "node -e \"require('fs').rmSync('.tmp-tools',{recursive:true,force:true})\" && tsc -p tsconfig.tools.json && node .tmp-tools/scripts/catalog-report.js",
    "check": "npm run typecheck && npm test && npm run catalog:validate && npm run build"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.699.0",
    "@aws-sdk/s3-request-presigner": "^3.699.0",
    "@sentry/nextjs": "^8.42.0",
    "@supabase/ssr": "^0.5.2",
    "@supabase/supabase-js": "^2.47.10",
    "next": "^15.1.3",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "resend": "^4.0.1"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "@types/react": "^19.0.2",
    "@types/react-dom": "^19.0.2",
    "autoprefixer": "^10.4.20",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.7.2"
  }
}
