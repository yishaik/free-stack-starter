# ─────────────────────────────────────────────────────────────────────────────
# Copy this file to `.env.local` and fill in real values. NEVER commit `.env.local`.
# Apply `supabase/schema.sql` to enable auth profiles, My Stack, RLS and distributed
# credential-test rate limiting.
# ─────────────────────────────────────────────────────────────────────────────

# ── Supabase (Database + Auth) — https://supabase.com → Project → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key
# Server-only. Used for the private distributed rate limiter; never expose it to browsers.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# At least 32 random bytes. Used to HMAC client identities before rate-limit storage.
# Generate with: openssl rand -base64 32
RATE_LIMIT_SECRET=replace-with-a-long-random-secret

# ── Resend (Transactional email) — https://resend.com → API Keys
RESEND_API_KEY=re_your_api_key
# A verified sender on your domain, e.g. "hello@yourdomain.com"
EMAIL_FROM=onboarding@resend.dev

# ── Sentry (Error tracking) — https://sentry.io → Project → Settings → Client Keys (DSN)
NEXT_PUBLIC_SENTRY_DSN=https://examplePublicKey@o0.ingest.sentry.io/0
# Optional, for source-map upload at build time (Settings → Auth Tokens)
SENTRY_AUTH_TOKEN=
SENTRY_ORG=your-org
SENTRY_PROJECT=free-stack-starter

# ── Cloudflare R2 (Object storage, S3-compatible, zero egress)
# Cloudflare Dashboard → R2 → Manage R2 API Tokens
R2_ACCOUNT_ID=your-cloudflare-account-id
R2_ACCESS_KEY_ID=your-r2-access-key-id
R2_SECRET_ACCESS_KEY=your-r2-secret-access-key
R2_BUCKET=uploads
# Optional: a public custom domain bound to the bucket for read URLs
R2_PUBLIC_BASE_URL=https://assets.yourdomain.com

# ── App
# Exact public origin used for same-origin validation on write endpoints.
NEXT_PUBLIC_SITE_URL=http://localhost:3000
