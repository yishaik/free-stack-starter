# ─────────────────────────────────────────────────────────────────────────────
# Copy this file to `.env.local` and fill in real values. NEVER commit `.env.local`.
# Every service here has a free tier — see docs/STACK-GUIDE.md.
# ─────────────────────────────────────────────────────────────────────────────

# ── Supabase (Database + Auth) — https://supabase.com → Project → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key
# server-only; used for admin tasks. Do NOT expose to the browser.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ── Resend (Transactional email) — https://resend.com → API Keys
RESEND_API_KEY=re_your_api_key
# a verified sender on your domain, e.g. "hello@yourdomain.com"
EMAIL_FROM=onboarding@resend.dev

# ── Sentry (Error tracking) — https://sentry.io → Project → Settings → Client Keys (DSN)
NEXT_PUBLIC_SENTRY_DSN=https://examplePublicKey@o0.ingest.sentry.io/0
# optional, for source-map upload at build time (Settings → Auth Tokens)
SENTRY_AUTH_TOKEN=
SENTRY_ORG=your-org
SENTRY_PROJECT=free-stack-starter

# ── Cloudflare R2 (Object storage, S3-compatible, zero egress)
# Cloudflare Dashboard → R2 → Manage R2 API Tokens
R2_ACCOUNT_ID=your-cloudflare-account-id
R2_ACCESS_KEY_ID=your-r2-access-key-id
R2_SECRET_ACCESS_KEY=your-r2-secret-access-key
R2_BUCKET=uploads
# optional: a public custom domain bound to the bucket for read URLs
R2_PUBLIC_BASE_URL=https://assets.yourdomain.com

# ── App
NEXT_PUBLIC_SITE_URL=http://localhost:3000
