# Copy to .env.local. Never commit real values.

# Supabase — public browser-safe values. RLS remains the authorization boundary.
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key

# Resend — server only
RESEND_API_KEY=re_your_api_key
EMAIL_FROM=onboarding@resend.dev

# Sentry
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_AUTH_TOKEN=
SENTRY_ORG=
SENTRY_PROJECT=free-stack-starter

# Cloudflare R2 — server only
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=uploads
# Leave empty for private objects. Prefer signed reads in production.
R2_PUBLIC_BASE_URL=
UPLOAD_MAX_BYTES=10485760

# App
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Optional AI access — server only
HF_TOKEN=
